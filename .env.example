# ────────────────────────────────────────────────────────────────
# Kastor — Template de variáveis de ambiente
#
# Copie pra .env (que NÃO vai pro git) e preencha. No Portainer, cole o
# conteúdo na aba "Environment variables" da Stack ao invés de criar .env
# no servidor.
# ────────────────────────────────────────────────────────────────

# Porta exposta no host. Default 8080 pra evitar conflito com Chatwoot
# (que costuma usar 3000). Ajuste pra qualquer porta livre na sua VPS.
HOST_PORT=8080

# URL pública (sem barra no final). Usada nos emails de reset de senha
# pra montar o link de volta. Ex.: https://kastor.seudominio.com.br
PUBLIC_URL=

# Segredo de criptografia das sessões/tokens em disco.
# Gere uma vez:  openssl rand -hex 32
# Se deixar vazio, o app gera automaticamente em data/secret.bin —
# funciona, mas se você trocar o volume, todas as sessões expiram.
FLUXO_SECRET=

# Quantos dias uma sessão dura antes de expirar (default 30).
KASTOR_SESSION_DAYS=30

# ── SMTP (opcional — sem isso, "esqueci senha" não envia email) ──
# Funciona com Gmail (porta 587, secure=false), Sendgrid, Mailgun, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=Kastor <noreply@seudominio.com.br>
